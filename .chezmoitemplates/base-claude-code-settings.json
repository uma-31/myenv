{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "language": "japanese",
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm:*)",
      "Read(*.env)"
    ],
    "ask": ["Bash(sudo:*)"],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "pnpx ccstatusline@latest",
    "padding": 0
  }
}
